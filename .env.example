# BUMI_MCP_HOST=127.0.0.1
# BUMI_MCP_PORT=10774

# Dev / CI without hardware (recommended until Bumi EDU arrives)
BUMI_USE_MOCK_BRIDGE=1

# Physical bot (Jetson on tailnet or LAN)
# BUMI_IP=100.x.x.x
# BUMI_FALLBACK_IP=
# BUMI_BRIDGE_PORT=9090

# Optional override for bumi(operation=robot_status) HTTP ping
# BUMI_ROBOT_URL=http://127.0.0.1:10774

# Motion gate — keep OFF until Noetix SDK topics are validated on hardware
# BUMI_ALLOW_MOTION=0
# BUMI_IMU_TOPIC=/imu/data
# BUMI_BATTERY_TOPIC=/battery_state
# BUMI_JOINT_STATES_TOPIC=/joint_states
# BUMI_WALK_CMD_TOPIC=/bumi/walk_cmd
# BUMI_ESTOP_TOPIC=/bumi/estop
